# Public site URL (used for sitemap/OG). Production: https://petgadgethub.co.uk (also set in Vercel).
NEXT_PUBLIC_SITE_URL=https://petgadgethub.co.uk

# Optional: Amazon Creators API (when eligible). Leave unset to use data/products.json fallback.
AMAZON_CREATORS_API_BASE=
AMAZON_CREATORS_API_KEY=

# Optional: Product Advertising API 5 — local script only (scripts/paapi-update-amazon-images.ts).
# Requires Associates + PA-API approval. Not used at runtime by the Next.js app.
AMAZON_PA_API_ACCESS_KEY=
AMAZON_PA_API_SECRET_KEY=
AMAZON_PA_API_PARTNER_TAG=
# UK defaults if unset: webservices.amazon.co.uk + eu-west-1
AMAZON_PA_API_HOST=
AMAZON_PA_API_REGION=

# Optional: protect /internal/* (except /internal/login). Generate a long random string.
INTERNAL_SECRET=

# Stripe — Premium Rental Pack checkout (create a £2.99 Product + Price in Stripe Dashboard).
STRIPE_SECRET_KEY=
STRIPE_PRICE_RENTAL_PACK=
