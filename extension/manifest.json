{
  "manifest_version": 3,
  "name": "PetGadgetHub UK Deal Hunter",
  "version": "0.1.0",
  "description": "Alerts when a UK retailer may beat the Amazon.co.uk price (affiliate-safe links).",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.amazon.co.uk/*"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "PetGadgetHub Deal Hunter"
  }
}
